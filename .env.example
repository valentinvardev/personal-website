# Since the ".env" file is gitignored, you can use the ".env.example" file to
# build a new ".env" file when you clone the repo. Keep this file up-to-date
# when you add new variables to `.env`.

# This file will be committed to version control, so make sure not to have any
# secrets in it. If you are cloning this repo, create a copy of this file named
# ".env" and populate it with your secrets.

# When adding additional environment variables, the schema in "/src/env.js"
# should be updated accordingly.

# ---- Panel de admin (/admin) ----
# Mínimo 8 caracteres. Usá algo largo y único en producción.
ADMIN_PASSWORD="cambiame-ya-12345"

# ---- Base de datos (Supabase, COMPARTIDA con el proyecto de facturación) ----
# ⚠️ El parámetro `schema=personal_site` es OBLIGATORIO: aísla las tablas de
# este proyecto en su propio schema de Postgres. Sin él, Prisma intentaría
# gestionar `public`, donde viven las tablas del otro proyecto.
# DATABASE_URL: "Transaction pooler" (puerto 6543) + pgbouncer — la usa la app.
# DIRECT_URL:   "Session pooler" o conexión directa (puerto 5432) — migraciones.
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-1-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&schema=personal_site"
DIRECT_URL="postgresql://postgres.<ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres?schema=personal_site"

# ---- Supabase (opcional por ahora; para Storage de capturas, etc.) ----
NEXT_PUBLIC_SUPABASE_URL="https://<ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_…"
SUPABASE_SECRET_KEY="sb_secret_…"
